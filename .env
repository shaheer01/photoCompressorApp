NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:3001

# Database Configuration  
DB_HOST=mysql
DB_PORT=3308
DB_NAME=imageoptim_db
DB_USER=imageoptim_user
DB_PASSWORD=your_secure_password
DB_ROOT_PASSWORD=root_secure_password

# JWT Configuration
JWT_SECRET=this_is_a_very_secure_jwt_secret_key_32_chars_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=refresh_token_secret_also_32_characters_long
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Configuration (Test Keys)
STRIPE_SECRET_KEY=sk_test_placeholder_key
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_key
STRIPE_WEBHOOK_SECRET=whsec_placeholder_secret
STRIPE_MONTHLY_PRICE_ID=price_test_monthly
STRIPE_YEARLY_PRICE_ID=price_test_yearly

# Email Configuration (Optional for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test_password
FROM_EMAIL=noreply@imageoptim.local
FROM_NAME=ImageOptim

# Google AdSense Configuration (Live values)
ADSENSE_PUBLISHER_ID=ca-pub-3643310427710829
ADSENSE_BANNER_SLOT_ID=0000000000
ADSENSE_SIDEBAR_SLOT_ID=1111111111  
ADSENSE_RESULTS_SLOT_ID=2222222222
ADSENSE_ANALYTICS_SLOT_ID=3333333333

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE_MB=100
UPLOAD_PATH=/app/uploads

# Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log

# Security
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=session_secret_for_development_use

# Redis (Optional)
REDIS_URL=redis://redis:6380
REDIS_PASSWORD=redis_dev_password

# Docker Configuration
FRONTEND_PORT=8888
FRONTEND_HTTPS_PORT=443
BACKEND_PORT=3001